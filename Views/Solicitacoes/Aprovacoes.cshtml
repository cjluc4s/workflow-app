@model IEnumerable<WorkflowApp.Models.Solicitacao>

@{
    ViewData["Title"] = "Painel de Aprovações";
}

<h2>Painel de Aprovações</h2>

<table class="table table-striped table-hover">
    <thead class="table-light">
        <tr>
            <th>Título</th>
            <th>Criado por</th>
            <th>Data</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td>@item.Usuario?.Email</td>
                    <td>@item.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Detalhes"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                            Detalhes
                        </a>

                        <a asp-action="Aprovar"
                           asp-route-id="@item.Id"
                           class="btn btn-success btn-sm">
                            Aprovar
                        </a>

                        <a asp-action="Rejeitar"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Rejeitar
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-muted">
                    Nenhuma solicitação pendente.
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Voltar</a>